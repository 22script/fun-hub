-- NOTIFICATION FUNCTION (Works on PC & Mobile)
local function sendNotification(message, duration)
    local notifFrame = Instance.new("Frame")
    notifFrame.Size = UDim2.new(0, 250, 0, 45)
    notifFrame.Position = UDim2.new(0.5, -125, 0, -60) -- Starts off-screen (top)
    notifFrame.BackgroundColor3 = Color3.fromRGB(20, 15, 25)
    notifFrame.BorderSizePixel = 0
    notifFrame.Parent = mainGui

    local notifCorner = Instance.new("UICorner", notifFrame)
    notifCorner.CornerRadius = UDim.new(0, 8)

    -- Add a subtle border glow matching your theme
    local notifStroke = Instance.new("UIStroke", notifFrame)
    notifStroke.Color = Color3.fromRGB(255, 0, 255)
    notifStroke.Thickness = 1.5

    local notifText = Instance.new("TextLabel", notifFrame)
    notifText.Size = UDim2.new(1, 0, 1, 0)
    notifText.BackgroundTransparency = 1
    notifText.Text = message
    notifText.TextColor3 = Color3.fromRGB(255, 200, 255)
    notifText.Font = Enum.Font.GothamBold
    notifText.TextSize = 16

    -- Tween In (Slide down)
    local tweenIn = TweenService:Create(notifFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0.5, -125, 0, 20)})
    tweenIn:Play()

    -- Wait and Tween Out (Slide back up)
    task.spawn(function()
        task.wait(duration)
        local tweenOut = TweenService:Create(notifFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(0.5, -125, 0, -60)})
        tweenOut:Play()
        tweenOut.Completed:Wait()
        notifFrame:Destroy()
    end)
end

